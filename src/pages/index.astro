---
import Layout from "../layouts/Layout.astro";
import Button from "../components/shared/Button.tsx";
import { ArrowRight } from "lucide-react";
import logo from "../assets/logo.svg";

const SignupLink = "https://app.heyoto.eu/signup";
const SiteLink = "https://heyoto.eu";
---

<Layout>
  <section
    class="relative w-full max-w-2xl overflow-hidden rounded-4xl bg-linear-to-br from-white via-white to-primary/10 px-6 py-12 text-center shadow-[0_24px_80px_-48px_rgba(30,64,175,0.45)] ring-1 ring-primary/10 sm:px-12 sm:py-16"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-linear-to-b from-primary/10 to-transparent"
    >
    </div>
    <div
      class="pointer-events-none absolute -right-20 top-20 h-56 w-56 rounded-full bg-primary/15 blur-3xl"
    >
    </div>
    <div
      class="pointer-events-none absolute -left-16 bottom-0 h-48 w-48 rounded-full bg-secondary/20 blur-3xl"
    >
    </div>

    <div class="relative flex flex-col items-center">
      <a
        href={SiteLink}
        class="mb-8 flex items-center gap-x-2 text-2xl font-bold text-primary"
      >
        <img src={logo.src} alt="OTO logo" width="32" height="32" /> OTO
      </a>

      <p
        class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary"
      >
        Prep your 1:1s in minutes
      </p>

      <h1
        class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl md:text-5xl md:leading-[1.05]"
      >
        <span class="block">Great managers don't</span>
        <span class="block">wing their 1:1s.</span>
        <span class="block text-primary">Neither should you.</span>
      </h1>

      <p
        class="mx-auto mt-4 max-w-md text-base leading-relaxed text-muted-foreground sm:text-lg"
      >
        OTO keeps templates, notes, and to-do's in one place so managers can focus
        on leading, not prep. Run your next 1:1 better, and make it count.
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <Button
          href={SignupLink}
          classes="w-full justify-center sm:w-auto"
          client:load
        >
          Try OTO free
          <ArrowRight className="h-4 w-4" />
        </Button>
        <Button
          href={SiteLink}
          type="secondary"
          classes="w-full justify-center sm:w-auto"
          client:load
        >
          See how it works
        </Button>
      </div>

      <p class="mt-8 text-xs text-muted-foreground">
        getoto.eu is the official mailing domain for OTO.
      </p>
    </div>
  </section>
</Layout>
